# ===== [OPTION 5] BƠM SCRIPT LUA CAN THIỆP THẲNG VÀO ENGINE ROBLOX =====
super_fix_lag() {
clear
echo -e "${BOLD}${YELLOW}--- [5] TỰ ĐỘNG BƠM SCRIPT SIÊU FIX LAG & LOCK FPS NỘI BỘ ---${RESET}"

if [ ${#selected_clients[@]} -eq 0 ]; then
    echo -e "${RED}Lỗi: Bạn chưa chọn Nick ở Option 2!${RESET}"
    sleep 2; return
fi

local LUA_FILE="/sdcard/Termux_SuperFixLag.lua"

cat << 'EOL' > "$LUA_FILE"
repeat wait() until game:IsLoaded()

pcall(function()
if setfpscap then
setfpscap($TARGET_FPS)
print("Đã khóa FPS thành công ở mức: " .. tostring($TARGET_FPS))
end
end)

local workspace = game:GetService("Workspace")
local lighting = game:GetService("Lighting")
lighting.GlobalShadows = false

for _, obj in pairs(workspace:GetDescendants()) do
if obj:IsA("BasePart") then
obj.Material = Enum.Material.SmoothPlastic
obj.Reflectance = 0
end
if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
obj:Destroy()
end
local name = obj.Name:lower()
if name:match("tree") or name:match("leaf") or name:match("grass") or name:match("house") or name:match("building") then
pcall(function() obj:Destroy() end)
end
end
EOL

