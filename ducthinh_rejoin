# ===== CÁC HÀM CHỌN NICK & CÀI ĐẶT MAP =====
menu_choose_client() {
clear
echo -e "${BOLD}${YELLOW}--- [2] CHỌN APP / NICK ---${RESET}"
local lines=$(pm list packages 2>/dev/null | grep -vE "com.android|com.google|android.ext|com.qualcomm|com.miui|com.termux" | tr -d '\r')
local -a pkgs=()
while IFS= read -r l; do pkg=$(echo "$l" | awk -F':' '{print $2}' | tr -d '[:space:]'); [ -n "$pkg" ] && pkgs+=("$pkg"); done <<< "$lines"

for (( i=0; i<${#pkgs[@]}; i++ )); do echo -e "  $((i+1))) ${pkgs[$i]}"; done
echo -e "  0) Treo TẤT CẢ"

read -r -p "Chọn số (Cách nhau bằng dấu cách): " choices
if [ -z "$choices" ]; then return; fi

selected_clients=()
if [ "$choices" == "0" ]; then selected_clients=("${pkgs[@]}");
else
    for num in $choices; do
        if [[ "$num" =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le "${#pkgs[@]}" ]; then
            selected_clients+=("${pkgs[$((num-1))]}")
        fi
    done
fi
for i in "${!selected_clients[@]}"; do client_places[$i]="$PLACE_ID"; client_vips[$i]="$VIP_LINK"; done
echo "Đã lưu ${#selected_clients[@]} nick thành công!"; sleep 1
}

