# ===== XỬ LÝ RAM CẤP ĐỘ HỆ THỐNG =====
get_sys_ram() {
local mems=($(awk '/MemTotal/ {t=$2} /MemAvailable/ {a=$2} /MemFree/ {f=$2} /^Cached/ {c=$2} END {if(a=="") a=f+c; print int((t-a)/1024)"#"int(t/1024)}' /proc/meminfo 2>/dev/null | tr '#' ' '))
echo "${mems[0]}MB / ${mems[1]}MB"
}

get_app_ram() {
    local pkg="$1"
    local raw_mem=$(/system/bin/dumpsys meminfo 2>/dev/null | grep -m 1 "$pkg (pid" | awk '{print $1}' | tr -d 'K:,')
    
    if [[ "$raw_mem" =~ ^[0-9]+$ ]] && [ "$raw_mem" -gt 0 ]; then
        echo $((raw_mem / 1024))
    else
        echo "0"
    fi
}

# ===== CHECK DISCONNECT SIÊU CHUẨN =====
check_running() {
    local pkg="$1"
    local mem=$(get_app_ram "$pkg")

    # Đã giữ nguyên mốc chặn 750MB chuẩn để né kẹt sảnh chờ 682MB
    if [ "$mem" -gt 750 ]; then
        if logcat -d -t 50 2>/dev/null | grep "$pkg" | grep -q -iE "disconnected|kick|connection lost|error code|connection timed out"; then
            am force-stop "$pkg" >/dev/null 2>&1
            logcat -c 2>/dev/null
            return 1
        fi
        return 0
    fi
    return 1
}

# ===== HÀM MỞ NICK SẠCH SẼ =====
launch_client() {
local pkg="$1"; local place_id="$2"; local vip_link="$3"
am force-stop "$pkg" >/dev/null 2>&1
sleep 1

local clean_code=""
if [ -n "$vip_link" ] && [ "$vip_link" != "0" ]; then
    if echo "$vip_link" | grep -q "privateServerLinkCode="; then
        clean_code=$(echo "$vip_link" | grep -o 'privateServerLinkCode=[^&]*' | cut -d'=' -f2)
    elif echo "$vip_link" | grep -q "code="; then
        clean_code=$(echo "$vip_link" | grep -o 'code=[^&]*' | cut -d'=' -f2)
    else 
        clean_code="$vip_link" 
    fi
fi

local uri="roblox://placeId=${place_id}"
[ -n "$clean_code" ] && uri="${uri}&linkCode=${clean_code}"

monkey -p "$pkg" -c android.intent.category.LAUNCHER 1 >/dev/null 2>&1
sleep 15

am start -p "$pkg" -a android.intent.action.VIEW -d "$uri" >/dev/null 2>&1
am start -n "$pkg/com.roblox.client.ActivitySplash" -a android.intent.action.VIEW -d "$uri" >/dev/null 2>&1
}

# ===== LUỒNG CHẠY CHÍNH VỚI DASHBOARD TĨNH =====
start_farm() {
if [ ${#selected_clients[@]} -eq 0 ]; then return; fi
clear

echo -e "${YELLOW}=== ĐANG KHỞI CHẠY TUẦN TỰ DANH SÁCH CLIENT ===${RESET}"
for i in "${!selected_clients[@]}"; do
local pkg="${selected_clients[$i]}"
echo -e "Kích hoạt luồng game thứ $((i+1)): ${CYAN}$pkg${RESET}..."
launch_client "$pkg" "${client_places[$i]}" "${client_vips[$i]}"
echo -e "${YELLOW}>> Đang chờ thêm 30 giây để game load ổn định...${RESET}"
sleep 30
done

clear
logcat -c 2>/dev/null

while true; do
printf "\e[H"
local sys_ram=$(get_sys_ram)

echo -e "${CYAN}==================================================================${RESET}"  
echo -e "                 LIVE DASHBOARD TĨNH - ĐỨC THỊNH ULTRA REJOIN     ${RESET}"  
echo -e "${CYAN}==================================================================${RESET}"  
echo -e "${YELLOW}>> Máy ảo: ${BOLD}${CYAN}${sys_ram}${RESET} | Đang cày: ${GREEN}${#selected_clients[@]} Nick${RESET} | FPS cấu hình: ${YELLOW}$TARGET_FPS${RESET}"  
echo -e "${CYAN}------------------------------------------------------------------${RESET}"  
echo -e "${BOLD}TÊN FILE APP              | TRẠNG THÁI     | RAM ALLOCATED        ${RESET}"  
echo -e "${CYAN}------------------------------------------------------------------${RESET}"  
  
for i in "${!selected_clients[@]}"; do  
  local pkg="${selected_clients[$i]}"  
  local short_pkg="${pkg:0:23}"  
    
  if check_running "$pkg"; then  
    local app_ram=$(get_app_ram "$pkg")  
    printf "%-25s | ${GREEN}Đang hoạt động${RESET} | ${YELLOW}%-4s MB${RESET}\n" "$short_pkg" "$app_ram"  
  else  
    printf "%-25s | ${RED}Đang Rejoin...${RESET} | %-7s\n" "$short_pkg" "0 MB"  
    launch_client "$pkg" "${client_places[$i]}" "${client_vips[$i]}"  
    sleep 30  
  fi  
done  
  
echo -e "${CYAN}------------------------------------------------------------------${RESET}"  
echo -e "Giữ nút Ctrl + C để dừng Tool."  
sleep $CHECK_INTERVAL
done
}

